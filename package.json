{
  "name": "redbar",
  "version": "0.1.0",
  "description": "Spec-driven test agents for every layer. Math finds what you changed that nothing tests; agents write it — unit, integration, e2e — following your team's spec, not the model's.",
  "type": "module",
  "private": true,
  "license": "MIT",
  "author": "Emerson Silva",
  "repository": {
    "type": "git",
    "url": "https://github.com/emersonjds/redbar.git"
  },
  "keywords": [
    "testing",
    "code-coverage",
    "test-generation",
    "ai-agents",
    "spec-driven",
    "ci",
    "mcp"
  ],
  "engines": {
    "node": ">=20.11"
  },
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "coverage": "vitest run --coverage --coverage.reporter=lcov",
    "try": "tsx scripts/try.ts"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
